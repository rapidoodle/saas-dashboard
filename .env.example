# ── Database ───────────────────────────────────────────────────────────────────
# Local Postgres:
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/saas_dashboard"

# Vercel Postgres (Neon) — copy from your Vercel project's Storage tab:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?pgbouncer=true&connect_timeout=15"
# DATABASE_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST/DB"
# (If using Neon, also uncomment the directUrl line in prisma/schema.prisma)

# ── NextAuth.js ────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
