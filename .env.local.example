# ──────────────────────────────────────────────
# Database (Vercel Postgres / Neon)
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ──────────────────────────────────────────────
# NextAuth
# ──────────────────────────────────────────────
NEXTAUTH_SECRET="your-random-secret-here"        # openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# ──────────────────────────────────────────────
# Amazon SP-API — Login with Amazon (LWA)
# Get these from developer.amazon.com > Apps & Services > Selling Partner App
# ──────────────────────────────────────────────
AMAZON_CLIENT_ID="amzn1.application-oa2-client.xxxx"
AMAZON_CLIENT_SECRET="your-lwa-client-secret"
AMAZON_REFRESH_TOKEN="Atzr|your-refresh-token"   # from SP-API Authorization flow

# ──────────────────────────────────────────────
# Amazon SP-API — AWS IAM credentials
# Create an IAM user with AmazonSellingPartnerAPIRole
# ──────────────────────────────────────────────
AMAZON_AWS_ACCESS_KEY="AKIAIOSFODNN7EXAMPLE"
AMAZON_AWS_SECRET_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
AMAZON_AWS_REGION="us-east-1"

# ──────────────────────────────────────────────
# Amazon seller details
# ──────────────────────────────────────────────
AMAZON_MARKETPLACE_ID="ATVPDKIKX0DER"   # US marketplace (see full list in SP-API docs)
AMAZON_SELLER_ID="A1EXAMPLE000000"       # Your Merchant/Seller ID from Seller Central
